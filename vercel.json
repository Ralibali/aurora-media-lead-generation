{
  "redirects": [
    { "source": "/om-oss-2", "destination": "/om", "permanent": true },
    { "source": "/om-oss-2/", "destination": "/om", "permanent": true },
    { "source": "/post-3", "destination": "/blogg", "permanent": true },
    { "source": "/post-3/", "destination": "/blogg", "permanent": true },
    { "source": "/post-5", "destination": "/blogg", "permanent": true },
    { "source": "/post-5/", "destination": "/blogg", "permanent": true },
    { "source": "/blog", "destination": "/blogg", "permanent": true },
    { "source": "/blog/", "destination": "/blogg", "permanent": true },
    { "source": "/artiklar", "destination": "/blogg", "permanent": true },
    { "source": "/artiklar/", "destination": "/blogg", "permanent": true },
    { "source": "/artiklar/:slug", "destination": "/blogg/:slug", "permanent": true },
    { "source": "/webbbyra-linkoping", "destination": "/webbyra-linkoping", "permanent": true },
    { "source": "/webbbyra-linkoping/", "destination": "/webbyra-linkoping", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
